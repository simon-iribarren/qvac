## Usage

### Provider

```typescript
import { startQVACProvider } from "@qvac/sdk"

const response = await startQVACProvider({
  topic: "66646f696865726f6569686a726530...",
  firewall: {                    // Optional
    mode: "allow",
    publicKeys: [consumerKey],
  },
})
// response.publicKey — share this with consumers
```

### Consumer

```typescript
import { loadModel, completion, LLAMA_3_2_1B_INST_Q4_0 } from "@qvac/sdk"

const modelId = await loadModel({
  modelSrc: LLAMA_3_2_1B_INST_Q4_0,
  modelType: "llm",
  delegate: {
    topic: topicHex,
    providerPublicKey: providerPubKey,
    timeout: 5_000,
    fallbackToLocal: true,
  },
})

const response = completion({
  modelId,
  history: [{ role: "user", content: "Hello!" }],
  stream: true,
})

for await (const token of response.tokenStream) {
  process.stdout.write(token)
}
```
