{
  "name": "@qvac/llm-llamacpp",
  "version": "0.3.2",
  "description": "llama addon for qvac",
  "addon": true,
  "scripts": {
    "build": "bare-make generate && bare-make build && bare-make install",
    "build:pack": "mkdir -p dist && npm pack --pack-destination dist",
    "mobile:copy-prebuilds": "cp -r prebuilds/android-arm64 prebuilds/android-ia32 || echo 'Warning: Failed to copy llamacpp prebuilds to android-ia32'; cp -r prebuilds/android-arm64 prebuilds/android-arm || echo 'Warning: Failed to copy llamacpp prebuilds to android-arm'; cp -r prebuilds/android-arm64 prebuilds/android-x64 || echo 'Warning: Failed to copy llamacpp prebuilds to android-x64'; cp -r prebuilds/ios-arm64 prebuilds/ios-arm64-simulator 2>/dev/null || echo 'iOS prebuilds already present'; cp -r prebuilds/ios-arm64 prebuilds/ios-x64-simulator 2>/dev/null || echo 'iOS prebuilds already present'",
    "lint": "standard --ignore \"addon/**\"",
    "lint:fix": "standard --ignore \"addon/**\" --fix",
    "update:quickstart-section": "node ./scripts/quickstart-testing/update_readme.js",
    "test": "npm run test:integration",
    "test:integration": "npm run test:integration:generate && bare test/integration/all.js --exit | tee test-output.log",
    "test:integration:moe": "bare test/integration/addon.test.moe.js --solo",
    "test:unit": "bare test/unit/addon.test.js",
    "model:init": "qvac-dev model init",
    "model:new": "qvac-dev model new",
    "model:generate": "qvac-dev model generate",
    "test:dts": "tsc index.d.ts --noEmit",
    "test:integration:generate": "brittle -r test/integration/all.js test/integration/*.test.js"
  },
  "standard": {
    "ignore": [
      "addon/lib/"
    ]
  },
  "files": [
    "binding.js",
    "index.js",
    "addon.js",
    "addonLogging.js",
    "settings.js",
    "prebuilds",
    "index.d.ts",
    "test/mobile"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/qvac-lib-infer-llamacpp-llm.git"
  },
  "author": "Tether",
  "license": "Apache-2.0",
  "bugs": "https://github.com/tetherto/qvac-lib-infer-llamacpp-llm/issues",
  "homepage": "https://github.com/tetherto/qvac-lib-infer-llamacpp-llm#readme",
  "devDependencies": {
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@qvac/dl-base": "^0.1.0",
    "@qvac/dl-filesystem": "^0.1.0",
    "@qvac/dl-hyperdrive": "^0.1.0",
    "@qvac/logging": "^0.1.0",
    "bare-buffer": "^3.1.0",
    "bare-fetch": "^2.5.0",
    "bare-fs": "^3.0.1",
    "bare-process": "^4.2.1",
    "brittle": "^3.16.5",
    "cmake-bare": "^1.6.5",
    "cmake-vcpkg": "^1.1.0",
    "corestore": "^7.4.7",
    "hyperswarm": "^4.14.0",
    "os": "npm:bare-os@^3.6.2",
    "process": "npm:bare-node-process",
    "sinon": "^21.0.0",
    "standard": "^17.0.0",
    "tty": "npm:bare-tty@^5.0.3",
    "util": "npm:bare-utils@^1.5.1"
  },
  "dependencies": {
    "@qvac/infer-base": "^0.1.0",
    "@qvac/response": "^0.1.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.2.1",
    "require-asset": "^1.1.0"
  },
  "engines": {
    "bare": ">=1.19.0"
  },
  "peerDependencies": {
    "@qvac/dl-hyperdrive": "^0.1.0"
  },
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "types": "index.d.ts"
}
